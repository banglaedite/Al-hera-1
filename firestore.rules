rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() { return request.auth != null; }
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == "banglaedite@gmail.com"
      );
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Students
    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Transactions
    match /transactions/{transactionId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Exams
    match /exams/{examId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Attendance
    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Donations
    match /donations/{donationId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Results
    match /results/{resultId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Hifz Records
    match /hifz_records/{hifzRecordId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Subjects
    match /subjects/{subjectId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Notices
    match /notices/{noticeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Expenses
    match /expenses/{expenseId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Income
    match /income/{incomeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Teachers
    match /teachers/{teacherId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Teacher Attendance
    match /teacher_attendance/{teacherAttendanceId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Food Menu
    match /food_menu/{foodMenuId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Site Settings
    match /site_settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Admissions
    match /admissions/{admissionId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Teacher Salaries
    match /teacher_salaries/{teacherSalaryId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Fee Setups
    match /fee_setups/{feeSetupId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Delete History
    match /delete_history/{deleteHistoryId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Job Applications
    match /job_applications/{jobApplicationId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Features
    match /features/{featureId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Slider Images
    match /slider_images/{sliderImageId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
