  "firestore": {
    "/students/{studentId}": { "schema": { "$ref": "Student" }, "description": "Collection of students." },
    "/transactions/{transactionId}": { "schema": { "$ref": "Transaction" }, "description": "Collection of payment transactions." },
    "/exams/{examId}": { "schema": { "$ref": "Exam" }, "description": "Collection of exams." },
    "/attendance/{attendanceId}": { "schema": { "$ref": "Attendance" }, "description": "Collection of attendance records." },
    "/donations/{donationId}": { "schema": { "$ref": "Donation" }, "description": "Collection of donations." },
    "/results/{resultId}": { "schema": { "$ref": "Result" }, "description": "Collection of results." },
    "/hifz_records/{hifzRecordId}": { "schema": { "$ref": "HifzRecord" }, "description": "Collection of hifz records." },
    "/subjects/{subjectId}": { "schema": { "$ref": "Subject" }, "description": "Collection of subjects." },
    "/notices/{noticeId}": { "schema": { "$ref": "Notice" }, "description": "Collection of notices." },
    "/expenses/{expenseId}": { "schema": { "$ref": "Expense" }, "description": "Collection of expenses." },
    "/income/{incomeId}": { "schema": { "$ref": "Income" }, "description": "Collection of income." },
    "/teachers/{teacherId}": { "schema": { "$ref": "Teacher" }, "description": "Collection of teachers." },
    "/teacher_attendance/{teacherAttendanceId}": { "schema": { "$ref": "TeacherAttendance" }, "description": "Collection of teacher attendance." },
    "/food_menu/{foodMenuId}": { "schema": { "$ref": "FoodMenu" }, "description": "Collection of food menu items." },
    "/site_settings/{settingId}": { "schema": { "$ref": "SiteSettings" }, "description": "Collection of site settings." },
    "/admissions/{admissionId}": { "schema": { "$ref": "Admission" }, "description": "Collection of admissions." },
    "/teacher_salaries/{teacherSalaryId}": { "schema": { "$ref": "TeacherSalary" }, "description": "Collection of teacher salaries." },
    "/fee_setups/{feeSetupId}": { "schema": { "$ref": "FeeSetup" }, "description": "Collection of fee setups." },
    "/delete_history/{deleteHistoryId}": { "schema": { "$ref": "DeleteHistory" }, "description": "Collection of delete history." },
    "/job_applications/{jobApplicationId}": { "schema": { "$ref": "JobApplication" }, "description": "Collection of job applications." },
    "/features/{featureId}": { "schema": { "$ref": "Feature" }, "description": "Collection of features." },
    "/slider_images/{sliderImageId}": { "schema": { "$ref": "SliderImage" }, "description": "Collection of slider images." },
    "/amal_tasks/{taskId}": { "schema": { "$ref": "AmalTask" }, "description": "Collection of Amal tasks." },
    "/amal_logs/{logId}": { "schema": { "$ref": "AmalLog" }, "description": "Collection of Amal daily logs." }
  }
