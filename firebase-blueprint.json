{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "Represents a student in the madrasa.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique student ID" },
        "name": { "type": "string", "description": "Student name (Bengali)" },
        "name_en": { "type": "string", "description": "Student name (English)" },
        "class": { "type": "string", "description": "Class name" },
        "roll": { "type": "string", "description": "Roll number" },
        "whatsapp": { "type": "string", "description": "WhatsApp number" },
        "photo_url": { "type": "string", "description": "URL of the student photo" },
        "father_name": { "type": "string", "description": "Father's name (Bengali)" },
        "father_name_en": { "type": "string", "description": "Father's name (English)" },
        "mother_name": { "type": "string", "description": "Mother's name (Bengali)" },
        "mother_name_en": { "type": "string", "description": "Mother's name (English)" },
        "dob": { "type": "string" },
        "blood_group": { "type": "string" },
        "birth_cert_no": { "type": "string" },
        "previous_school": { "type": "string" },
        "present_address": { "type": "string" },
        "permanent_address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "is_hifz": { "type": "number" },
        "admission_date": { "type": "string" },
        "monthly_fee": { "type": "number" },
        "biometric_id": { "type": "string", "description": "ID for biometric/RFID attendance machine" },
        "guardian_name": { "type": "string" },
        "guardian_relation": { "type": "string" },
        "guardian_nid": { "type": "string" },
        "guardian_mobile": { "type": "string" },
        "emergency_contact_name": { "type": "string" },
        "emergency_contact_relation": { "type": "string" },
        "emergency_contact_mobile": { "type": "string" },
        "deleted_at": { "type": "string" }
      },
      "required": ["id", "name", "class", "roll"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Represents a fee payment transaction.",
      "type": "object",
      "properties": {
        "transaction_id": { "type": "string", "description": "Unique transaction ID" },
        "student_id": { "type": "string", "description": "ID of the student" },
        "student_name": { "type": "string", "description": "Name of the student" },
        "student_class": { "type": "string", "description": "Class of the student" },
        "student_roll": { "type": "string", "description": "Roll of the student" },
        "category": { "type": "string", "description": "Fee category" },
        "amount": { "type": "number", "description": "Amount paid" },
        "paid_date": { "type": "string", "format": "date-time", "description": "Date of payment" }
      },
      "required": ["transaction_id", "student_id", "amount", "paid_date"]
    },
    "Exam": {
      "title": "Exam",
      "description": "Represents an exam.",
